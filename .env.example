# Copy to /config/.env (OUTSIDE public_html) and fill in. Never commit the real .env.
APP_NAME="Construction SaaS"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://example.com
APP_KEY=change_me_to_a_long_random_string

DB_HOST=localhost
DB_PORT=3306
DB_NAME=construction_saas
DB_USER=db_user
DB_PASS=db_password
DB_CHARSET=utf8mb4

# Absolute path to the storage dir (outside web root). Leave blank to use ../storage
STORAGE_PATH=

# Shared secret guarding the cron/compliance endpoint
CRON_TOKEN=change_me_cron_token

# Session cookie settings
SESSION_NAME=csaas_session
SESSION_SECURE=true

# Google reCAPTCHA (leave blank to disable the CAPTCHA until you add keys).
# Get keys at https://www.google.com/recaptcha/admin (reCAPTCHA v2 "I'm not a robot").
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=

# SMTP for outgoing email (password reset). Leave MAIL_HOST blank to fall back
# to logging the reset link into storage/logs/app.log instead of sending.
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_ENCRYPTION=tls
MAIL_FROM=no-reply@federaerp.com
MAIL_FROM_NAME="Federa ERP"
