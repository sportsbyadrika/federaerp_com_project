# Copy to /config/.env (OUTSIDE public_html) and fill in. Never commit the real .env.
APP_NAME="Construction SaaS"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://example.com
APP_KEY=change_me_to_a_long_random_string

DB_HOST=localhost
DB_PORT=3306
DB_NAME=construction_saas
DB_USER=db_user
DB_PASS=db_password
DB_CHARSET=utf8mb4

# Absolute path to the storage dir (outside web root). Leave blank to use ../storage
STORAGE_PATH=

# Shared secret guarding the cron/compliance endpoint
CRON_TOKEN=change_me_cron_token

# Session cookie settings
SESSION_NAME=csaas_session
SESSION_SECURE=true
